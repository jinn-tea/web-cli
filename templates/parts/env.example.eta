# Copy to .env.local and fill in. Every variable here is declared and validated
# in src/config/env.ts — add new ones there first or the app won't start.

# ── Browser-visible (NEXT_PUBLIC_* only) ────────────────────────────────────
# Where the browser sends data API calls (the external backend).
NEXT_PUBLIC_API_URL=<%= it.apiUrl %>
# Display name used in metadata and the app shell.
NEXT_PUBLIC_APP_NAME=<%= it.appName %>

# ── Server-only (NEVER prefixed NEXT_PUBLIC_) ───────────────────────────────
# Backend URL used by the /api/session route handlers. Defaults to
# NEXT_PUBLIC_API_URL when unset — set it when the server reaches the backend
# over a different (e.g. internal) address than the browser does.
# BACKEND_API_URL=<%= it.apiUrl %>

# Name of the httpOnly cookie holding the refresh token.
SESSION_COOKIE_NAME=session
