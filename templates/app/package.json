    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "nuqs": "^2.9.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.4",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.4",
